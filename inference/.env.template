# .env.template for feature_metadata upload script

# The ARN of the role to assume for uploading metadata to DynamoDB
# Replace <YOUR_AWS_ACCOUNT_ID> and <YOUR_ROLE_NAME> with your actual AWS account ID and the role name.
METADATA_UPLOADER_ROLE_ARN=arn:aws:iam::<YOUR_AWS_ACCOUNT_ID>:role/<YOUR_ROLE_NAME>

# The AWS region where your DynamoDB table is hosted
# Replace <YOUR_AWS_REGION> with your actual AWS region, e.g., us-east-1.
AWS_REGION=<YOUR_AWS_REGION>

# The name of your DynamoDB table for storing opportunity metadata
# Replace <YourDynamoDBTableName> with the actual name of your DynamoDB table.
OPPORTUNITY_METADATA_TABLE_NAME=<YourDynamoDBTableName>

# Path to the CSV file containing feature metadata
# If the CSV file is named feature_metadata.csv and located in the same directory as your script, you can leave this as is.
# Otherwise, replace this with the path to your CSV file.
FEATURE_METADATA_PATH=feature_metadata.csv
